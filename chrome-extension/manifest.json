{
  "manifest_version": 3,
  "name": "BaixarHSL - Capturador de Stream",
  "version": "1.0",
  "description": "Captura URLs de stream HLS (.m3u8) automaticamente enquanto você navega.",
  "permissions": ["webRequest", "storage", "tabs", "cookies"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "BaixarHSL"
  }
}
